# Copy to .env for local development. NEVER commit the real file.
GEMINI_API_KEY="your_google_ai_studio_api_key_here"

# Optional: require an access code before the app renders. Set this on any
# shared/hosted deployment — the tool ingests confidential client data.
# APP_PASSWORD="choose-a-long-random-string"

# Optional: structured error tracking (requires `pip install sentry-sdk`)
# SENTRY_DSN=""

# Optional: override where the audit log lives (e.g. a mounted volume)
# AUDIT_DB_PATH="/var/data/audit.db"

# Optional: log verbosity (JSON logs to stdout). Default INFO.
# LOG_LEVEL="INFO"
